{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user preferences and locality information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "locality": { "type": "string", "description": "The user's selected country." },
        "viewPreference": { "type": "string", "enum": ["country", "africa"], "description": "The user's preferred data view." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["uid", "email", "locality", "viewPreference"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document."
    }
  }
}
